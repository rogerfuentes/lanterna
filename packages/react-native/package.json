{
  "name": "@lanternajs/react-native",
  "version": "0.0.2",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "src",
    "ios",
    "android",
    "plugin"
  ],
  "license": "Apache-2.0",
  "description": "React Native in-app performance module for Lanterna",
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerfuentes/lanterna.git",
    "directory": "packages/react-native"
  },
  "publishConfig": {
    "access": "public"
  },
  "codegenConfig": {
    "name": "lanternamodule",
    "type": "modules",
    "jsSrcsDir": "./src/specs",
    "android": {
      "javaPackageName": "com.lanterna"
    }
  },
  "dependencies": {
    "@lanternajs/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
