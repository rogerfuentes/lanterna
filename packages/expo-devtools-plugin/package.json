{
  "name": "@lanternajs/expo-devtools-plugin",
  "version": "0.0.3",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "webui-dist"
  ],
  "license": "Apache-2.0",
  "description": "Expo DevTools plugin for Lanterna performance monitoring",
  "repository": {
    "type": "git",
