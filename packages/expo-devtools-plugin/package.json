    "directory": "packages/expo-devtools-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@lanternajs/core": "^0.0.3"
  },
  "peerDependencies": {
    "expo": ">=50.0.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:webui": "esbuild --bundle webui-dist/script.js --outfile=webui-dist/script-bundle.js --minify",
    "prepublishOnly": "npm run build",
    "test": "bun test"
