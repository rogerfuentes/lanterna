{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@lanterna/*": ["./packages/*/src"]
    }
  },
  "include": ["packages/*/src", "packages/react-native/plugin/src"]
}
